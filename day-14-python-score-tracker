scores = {}

while True:
    name = input("Enter student name (or type 'stop' to finish): ")

    if name.lower() == "stop":
        break

    score = int(input("Enter score: "))

    scores[name] = score

print("\nScore Board")
print("----------------")

for student, mark in scores.items():
    print(student, ":", mark)

if scores:
    highest = max(scores, key=scores.get)
    print("\nTop Scorer:", highest, "-", scores[highest])
